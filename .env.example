APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# WhatsApp Cloud API — webhook (Meta for Developers > App > WhatsApp > Configuration)
WHATSAPP_GRAPH_API_VERSION=v25.0
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=

# Buffer de mensagens WhatsApp (debounce antes do agente N8N — Fase 4)
WA_BUFFER_SHORT_WAIT_MS=1500
WA_BUFFER_MAX_WAIT_MS=3000

# Webhook do agente N8N — [agente] Cliente Final (Fase 6)
N8N_AGENT_WEBHOOK_URL=
# Webhook do agente N8N — [agente] Gestor (Fase 6). FlushMessageBufferJob escolhe
# este ou o de cima comparando o telefone do remetente com tenants.manager_phone.
N8N_MANAGER_AGENT_WEBHOOK_URL=

# Token de serviço fixo para chamadas N8N -> API (sub-workflows [agendamento] e
# [util] Buscar Contexto Cliente). Mesmo valor deve ser configurado na credencial
# "API Service Token" (httpHeaderAuth, header "Authorization", valor "Bearer <token>")
# no N8N. Gerar com: openssl rand -hex 32
N8N_API_SERVICE_TOKEN=

# Automações (Fase 4): horário do lembrete 24h (fuso do servidor) e hora local
# do tenant para o resumo matinal do gestor
APPOINTMENT_REMINDER_CRON_TIME=09:00
MANAGER_SUMMARY_LOCAL_HOUR=7

VITE_APP_NAME="${APP_NAME}"
